! Generated by ZTP Server from NetBox
! Device: {{ device.name }}  Serial: {{ device.serial }}
!
hostname {{ device.name }}
!
username admin privilege 15 role network-admin secret 0 {{ admin_password }}
!
aaa authentication login default local
!
management ssh
   no shutdown
!
management api http-commands
   protocol http
   no shutdown
!
{% if mgmt_iface and primary_ip %}
interface {{ mgmt_iface }}
   ip address {{ primary_ip }}
   no shutdown
!
ip route 0.0.0.0/0 {{ gateway }}
!
{% endif %}
