{% include 'eos/base.j2' %}
{% for w in config_warnings | default([]) %}
! ⚠ {{ w }}
{% endfor %}
{% if hardware and hardware.tcam_profile %}
hardware tcam
   system profile {{ hardware.tcam_profile }}
!
{% endif %}
{% if interface_defaults %}
interface defaults
{% if interface_defaults.mtu %}
   mtu {{ interface_defaults.mtu }}
{% endif %}
!
{% endif %}
ip routing
!
{% for vrf in vrfs %}
vrf instance {{ vrf.name }}
!
ip routing vrf {{ vrf.name }}
!
{% endfor %}
{% if ip_virtual_router_mac %}
ip virtual-router mac-address {{ ip_virtual_router_mac }}
!
{% endif %}
{% set switchport_ifaces = interfaces | selectattr('mode') | list %}
{% set svi_ifaces = interfaces | selectattr('name', 'match', '^Vlan') | list %}
{% set routed_ifaces = interfaces | rejectattr('mode') | rejectattr('name', 'match', '^Vlan') | rejectattr('name', 'match', '^Management') | list %}
{% if vlans %}
! === VLANs ===
{% for vlan in vlans %}
vlan {{ vlan.vid }}
   name {{ vlan.name }}
{% if vlan.trunk_groups %}
{% for tg in vlan.trunk_groups %}
   trunk group {{ tg }}
{% endfor %}
{% endif %}
!
{% endfor %}
{% endif %}
! === Underlay (routed) interfaces ===
{% for iface in routed_ifaces %}
{% if iface.ip_address or iface.lag %}
interface {{ iface.name }}
{% if iface.description %}
   description {{ iface.description }}
{% endif %}
{% if iface.lag %}
   channel-group {{ iface.lag.lag_id }} mode active
{% else %}
{% if iface.name is match('^Ethernet') %}
   no switchport
{% endif %}
   ip address {{ iface.ip_address }}
{% if iface.mtu %}
   mtu {{ iface.mtu }}
{% endif %}
{% if ospf_ifaces and iface.name in ospf_ifaces %}
   ip ospf area {{ ospf_ifaces[iface.name].area | default('0.0.0.0') }}
{% if ospf_ifaces[iface.name].network_type %}
   ip ospf network {{ ospf_ifaces[iface.name].network_type }}
{% endif %}
{% endif %}
{% endif %}
   {{ 'no shutdown' if iface.enabled else 'shutdown' }}
!
{% endif %}
{% endfor %}
{% if switchport_ifaces %}
! === Server-facing ports ===
{% for iface in switchport_ifaces %}
interface {{ iface.name }}
{% if iface.description %}
   description {{ iface.description }}
{% endif %}
{% if iface.mode == 'access' %}
   switchport mode access
{% if iface.untagged_vlan %}
   switchport access vlan {{ iface.untagged_vlan }}
{% endif %}
{% elif iface.mode == 'tagged' %}
   switchport mode trunk
{% if iface.tagged_vlans %}
   switchport trunk allowed vlan {{ iface.tagged_vlans | join(',') }}
{% endif %}
{% elif iface.mode == 'tagged-all' %}
   switchport mode trunk
{% endif %}
   {{ 'no shutdown' if iface.enabled else 'shutdown' }}
!
{% endfor %}
{% endif %}
{% if svi_ifaces %}
! === SVIs (L3 gateways) ===
{% for iface in svi_ifaces %}
{% if iface.ip_address %}
interface {{ iface.name }}
{% if iface.description %}
   description {{ iface.description }}
{% endif %}
{% if iface.vrf %}
   vrf {{ iface.vrf }}
{% endif %}
{% if iface.name == 'Vlan4094' %}
   ip address {{ iface.ip_address }}
{% else %}
   ip address virtual {{ iface.ip_address }}
{% endif %}
   {{ 'no shutdown' if iface.enabled else 'shutdown' }}
!
{% endif %}
{% endfor %}
{% endif %}
{% if mlag %}
! === MLAG peer-link ===
interface {{ mlag.peer_link }}
   description MLAG PEER-LINK
   switchport mode trunk
   switchport trunk group {{ mlag.trunk_group | default('MLAG_PEER') }}
!
! === MLAG ===
mlag configuration
   domain-id {{ mlag.domain_id }}
   local-interface {{ mlag.local_interface }}
   peer-address {{ mlag.peer_address }}
   peer-link {{ mlag.peer_link }}
   reload-delay mlag {{ mlag.reload_delay | default(300) }}
   reload-delay non-mlag {{ mlag.reload_delay_non_mlag | default(330) }}
!
{% endif %}
{% if vxlan %}
! === VXLAN ===
interface Vxlan1
   vxlan source-interface {{ vxlan.source_interface | default('Loopback0') }}
{% if vxlan.virtual_router_encapsulation %}
   vxlan virtual-router encapsulation mac-address {{ vxlan.virtual_router_encapsulation }}
{% endif %}
   vxlan udp-port {{ vxlan.udp_port | default(4789) }}
{% for entry in vxlan.vlan_vnis | default([]) %}
   vxlan vlan {{ entry.vlan }} vni {{ entry.vni }}
{% endfor %}
{% for vrf in vrfs if vrf.vni is defined %}
   vxlan vrf {{ vrf.name }} vni {{ vrf.vni }}
{% endfor %}
{% if vxlan.mlag_source_interface %}
   vxlan mlag source-interface {{ vxlan.mlag_source_interface }}
{% endif %}
{% if vxlan.flood_vteps %}
   vxlan flood vtep {{ vxlan.flood_vteps | join(' ') }}
{% endif %}
!
{% endif %}
{% if ospf %}
! === OSPF ===
router ospf {{ ospf.process_id | default(1) }}
   router-id {{ ospf.router_id | default(router_id) }}
{% if ospf.max_lsa %}
   max-lsa {{ ospf.max_lsa }}
{% endif %}
!
{% endif %}
{% for vrf in vrfs %}
{% if vrf.prefix_list and vrf.prefixes %}
! === Prefix-list / Route-map: {{ vrf.name }} ===
ip prefix-list {{ vrf.prefix_list }}
{% for prefix in vrf.prefixes %}
   seq {{ loop.index * 10 }} permit {{ prefix }}
{% endfor %}
!
route-map {{ vrf.route_map_export }} permit 10
   match ip address prefix-list {{ vrf.prefix_list }}
!
{% endif %}
{% endfor %}
{% if bgp %}
! === BGP ===
router bgp {{ bgp.asn }}
   router-id {{ bgp.router_id | default(router_id) }}
{% if bgp.no_default_ipv4 %}
   no bgp default ipv4-unicast
{% endif %}
{% if bgp.graceful_restart %}
   graceful-restart restart-time {{ bgp.graceful_restart_time | default(300) }}
   graceful-restart
{% endif %}
{% if bgp.send_community %}
   neighbor default send-community
{% endif %}
{% for neighbor in bgp.neighbors | default([]) %}
   neighbor {{ neighbor.ip }} remote-as {{ neighbor.remote_as }}
{% if neighbor.description %}
   neighbor {{ neighbor.ip }} description {{ neighbor.description }}
{% endif %}
{% if neighbor.update_source %}
   neighbor {{ neighbor.ip }} update-source {{ neighbor.update_source }}
{% endif %}
{% endfor %}
   !
{% for entry in vxlan.vlan_vnis | default([]) %}
   vlan {{ entry.vlan }}
      rd {{ router_id }}:{{ entry.vni }}
      route-target both {{ entry.vni }}:{{ entry.vni }}
      redistribute learned
   !
{% endfor %}
   address-family evpn
{% for neighbor in bgp.neighbors | default([]) %}
{% if neighbor.evpn %}
      neighbor {{ neighbor.ip }} activate
{% endif %}
{% endfor %}
   !
{% for vrf in vrfs %}
   vrf {{ vrf.name }}
      rd {{ router_id }}:{{ vrf.rd_suffix if vrf.rd_suffix else vrf.vni }}
      route-target import evpn {{ vrf.route_target }}
      route-target export evpn {{ vrf.route_target }}
{% if vrf.route_map_export %}
      redistribute connected route-map {{ vrf.route_map_export }}
{% else %}
      redistribute connected
{% endif %}
   !
{% endfor %}
!
{% endif %}
end
