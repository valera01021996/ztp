# Generated by ZTP Server from NetBox
# Device: {{ device.name }}  Serial: {{ device.serial }}
#
sysname {{ device.name }}
#
undo password-control enable
undo password-control update enable
#
local-user admin class manage
 password simple {{ admin_password }}
 service-type telnet ssh terminal
 authorization-attribute user-role network-admin
#
line vty 0 4
 authentication-mode scheme
 user-role network-admin
 protocol inbound ssh telnet
#
telnet server enable
ssh server enable
netconf enable
#
{% if mgmt_iface and primary_ip %}
interface {{ mgmt_iface | comware_iface }}
 ip address {{ primary_ip | cidr_to_mask }}
 undo shutdown
#
ip route-static 0.0.0.0 0 {{ gateway }}
#
{% endif %}
